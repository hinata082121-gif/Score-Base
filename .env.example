DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-secure-random-secret"
NEXTAUTH_URL="https://score-base.vercel.app"
AUTH_URL="https://score-base.vercel.app"
AUTH_TRUST_HOST="true"

# Vercel Supabase integration
# Vercel Marketplace may create these automatically.
# Recommended production setup: copy POSTGRES_PRISMA_URL into DATABASE_URL.
# The app can fall back to POSTGRES_PRISMA_URL, POSTGRES_URL, and POSTGRES_URL_NON_POOLING,
# but DATABASE_URL should still be set explicitly for Prisma CLI and operational clarity.
# POSTGRES_PRISMA_URL=""
# POSTGRES_URL=""
# POSTGRES_URL_NON_POOLING=""
# SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_URL=""

# Local PostgreSQL example
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/score_base?schema=public"

# Google OAuth future use
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
