generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String           @id @default(cuid())
  name               String?
  displayName        String?
  email              String?          @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  games              Game[]
  teams              Team[]
  ownedTeams         Team[]           @relation("TeamOwner")
  ownedGames         Game[]           @relation("GameOwner")
  createdGames       Game[]           @relation("GameCreatedBy")
  updatedGames       Game[]           @relation("GameUpdatedBy")
  ownedPlayers       Player[]         @relation("PlayerOwner")
  accounts           Account[]
  sessions           Session[]
  teamMemberships    TeamMember[]
  invitationsCreated Invitation[]     @relation("InvitationCreatedBy")
  invitationsAccepted Invitation[]    @relation("InvitationAcceptedBy")
  auditLogs          AuditLog[]
  snapshots          ExportSnapshot[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Team {
  id        String       @id @default(cuid())
  userId    String?
  ownerId   String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  owner     User?        @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  name      String
  shortName String?
  category  String?
  homeGround String?
  primaryColor String?
  memo      String?
  visibility String      @default("PRIVATE")
  sourceLocalId String?
  players   Player[]
  gameTeams GameTeam[]
  homeGames Game[]       @relation("HomeTeam")
  awayGames Game[]       @relation("AwayTeam")
  teamGames Game[]       @relation("WorkspaceTeam")
  members   TeamMember[]
  invitations Invitation[]
  auditLogs AuditLog[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([name])
  @@index([category])
  @@index([visibility])
  @@index([ownerId, sourceLocalId])
}

model Player {
  id             String            @id @default(cuid())
  teamId         String?
  ownerId        String?
  team           Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  owner          User?             @relation("PlayerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  name           String
  kana           String?
  number         String?
  throws         String?
  bats           String?
  throwingHand   String?
  battingSide    String?
  primaryPos     String?
  primaryPosition String?
  memo           String?
  visibility     String            @default("PRIVATE")
  sourceLocalId  String?
  lineupEntries  LineupEntry[]
  battingRecords PlateAppearance[] @relation("Batter")
  pitchingRecords PlateAppearance[] @relation("Pitcher")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([name])
  @@index([teamId])
  @@index([ownerId])
  @@index([visibility])
  @@index([ownerId, sourceLocalId])
  @@index([teamId, sourceLocalId])
}

model Game {
  id               String            @id @default(cuid())
  userId           String?
  ownerId          String?
  teamId           String?
  createdById      String?
  updatedById      String?
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  owner            User?             @relation("GameOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  team             Team?             @relation("WorkspaceTeam", fields: [teamId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("GameCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?             @relation("GameUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  mode             String
  gameDate         DateTime
  venue            String?
  competition      String?
  homeTeamId       String?
  awayTeamId       String?
  homeTeam         Team?             @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeam         Team?             @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: SetNull)
  homeTeamName     String
  awayTeamName     String
  favoriteTeamName String?
  weather          String?
  seatMemo         String?
  watchMemo        String?
  impressivePlayer String?
  mvp              String?
  result           String?
  photoMemo        String?
  isPublic         Boolean           @default(false)
  umpireMemo       String?
  status           String            @default("NORMAL")
  statusReason     String?
  calledReason     String?
  startTime        DateTime?
  endTime          DateTime?
  homeScore        Int?
  awayScore        Int?
  visibility       String            @default("PRIVATE")
  sourceLocalId    String?
  gameTeams        GameTeam[]
  lineups          LineupEntry[]
  inningScores     InningScore[]
  plateAppearances PlateAppearance[]
  gameNotes        GameNote[]
  snapshots        ExportSnapshot[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([gameDate])
  @@index([mode])
  @@index([status])
  @@index([teamId])
  @@index([createdById])
  @@index([updatedById])
  @@index([visibility])
  @@index([ownerId, sourceLocalId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("VIEWER")
  status    String   @default("ACTIVE")
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([role])
}

model Invitation {
  id           String    @id @default(cuid())
  teamId       String
  createdById  String?
  acceptedById String?
  team         Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy    User?     @relation("InvitationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  acceptedBy   User?     @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  email        String?
  code         String    @unique
  role         String    @default("VIEWER")
  status       String    @default("PENDING")
  expiresAt    DateTime?
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([teamId])
  @@index([status])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  teamId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  team         Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  action       String
  resourceType String
  resourceId   String?
  detail       String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([teamId])
  @@index([action])
  @@index([resourceType])
}

model GameTeam {
  id              String   @id @default(cuid())
  gameId          String
  teamId          String?
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  side            String
  teamName        String
  startingPitcher String?
  relayMemo       String?
  scoringMemo     String?
  winningPitcher  String?
  losingPitcher   String?
  savePitcher     String?
  homerunMemo     String?

  @@index([gameId])
  @@index([teamName])
}

model LineupEntry {
  id           String   @id @default(cuid())
  gameId       String
  playerId     String?
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player       Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  teamSide     String
  battingOrder Int?
  playerName   String
  position     String?
  number       String?
  uniformNumber String?
  role         String   @default("STARTER")
  isStarter    Boolean  @default(true)
  substitution String?
  memo         String?

  @@index([gameId, teamSide, battingOrder])
}

model InningScore {
  id        String @id @default(cuid())
  gameId    String
  game      Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  inning    Int
  topBottom String?
  runs      Int?
  hits      Int?
  errors    Int?
  leftOnBase Int?
  topRuns   Int    @default(0)
  bottomRuns Int   @default(0)

  @@unique([gameId, inning])
}

model PlateAppearance {
  id              String        @id @default(cuid())
  gameId          String
  game            Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  inning          Int
  topBottom       String
  battingOrder    Int
  batterId        String?
  batter          Player?       @relation("Batter", fields: [batterId], references: [id], onDelete: SetNull)
  pitcherId       String?
  pitcher         Player?       @relation("Pitcher", fields: [pitcherId], references: [id], onDelete: SetNull)
  batterName      String?
  pitcherName     String?
  balls           Int           @default(0)
  strikes         Int           @default(0)
  outsBefore      Int           @default(0)
  outsAfter       Int           @default(0)
  result          String
  rbi             Int           @default(0)
  runScored       Boolean       @default(false)
  baseStateBefore String?
  baseStateAfter  String?
  hitType         String?
  hitDirection    String?
  battedBallType  String?
  memo            String?
  pitchEvents     PitchEvent[]
  runnerEvents    RunnerEvent[]
  createdAt       DateTime      @default(now())

  @@index([gameId, inning, topBottom])
  @@index([batterId])
  @@index([pitcherId])
}

model PitchEvent {
  id                  String           @id @default(cuid())
  plateAppearanceId   String
  plateAppearance     PlateAppearance  @relation(fields: [plateAppearanceId], references: [id], onDelete: Cascade)
  pitchNumber         Int
  pitchCall           String
  speedKmh            Int?
  pitchType           String?
  course              String?
  memo                String?
  createdAt           DateTime         @default(now())

  @@unique([plateAppearanceId, pitchNumber])
}

model RunnerEvent {
  id                String          @id @default(cuid())
  plateAppearanceId String
  plateAppearance   PlateAppearance @relation(fields: [plateAppearanceId], references: [id], onDelete: Cascade)
  runnerName        String?
  fromBase          String?
  toBase            String?
  outcome           String
  rbiCredit         Boolean         @default(false)
  memo              String?
}

model GameNote {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  title     String?
  noteType  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExportSnapshot {
  id        String   @id @default(cuid())
  userId    String?
  gameId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  game      Game?    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  type      String
  style     String?
  fileName  String?
  imageUrl  String?
  dataJson  String?
  createdAt DateTime @default(now())

  @@index([type])
}
